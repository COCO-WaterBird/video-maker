# 复制为 .env 后填写（勿提交 .env）
OPENAI_API_KEY=sk-...

# --- 图片编辑费用（大头在这里；「跳过看图」只省 gpt-4o，省不了下面这块）---
# 模型：gpt-image-1-mini 通常比 gpt-image-1 便宜，效果可能略降
# OPENAI_IMAGE_MODEL=gpt-image-1

# 尺寸：1024x1024 一般比 auto / 1536 边更便宜；要画质再改 auto 或查官方文档
# OPENAI_IMAGE_EDIT_SIZE=1024x1024

# 质量：medium 比 high 便宜；要最佳再设 high
# OPENAI_IMAGE_EDIT_QUALITY=medium

# 输入保真：部分账号支持 low 略省（以 API 为准）
# OPENAI_IMAGE_INPUT_FIDELITY=high
